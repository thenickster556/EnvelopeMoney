<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Spinner / dropdown popups pick up primary + surface from overlay -->
    <!-- MaterialComponents (not Light) so DayNight can drive surface/onSurface via colors -->
    <style name="ThemeOverlay.MountainMoney.Spinner" parent="ThemeOverlay.MaterialComponents">
        <item name="colorPrimary">@color/mountain_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/spinner_popup_surface</item>
        <item name="colorOnSurface">@color/spinner_popup_on_surface</item>
    </style>
</resources>
